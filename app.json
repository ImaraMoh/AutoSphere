{
  "expo": {
    "name": "AutoSphere",
    "slug": "AutoSphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundImage": "./assets/logo/logo.png",
        "monochromeImage": "./assets/logo/logo.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.imaramoh.AutoSphere"
    },
    "web": {
      "favicon": "./assets/logo/logo.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AutoSphere to access camera for document scanning"
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ]
  }
}
